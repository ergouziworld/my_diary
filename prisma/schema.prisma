generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./prisma/dev.db"
}

enum InputType {
  text
  image
  audio
  video
  link
  file
  mixed
}

enum MediaType {
  image
  video
  audio
  file
}

enum TaskStatus {
  todo
  doing
  done
  archived
}

enum PriorityLevel {
  low
  medium
  high
  urgent
}

enum TimelineEventType {
  note
  milestone
  meeting
  decision
  task
  emotion
  relationship
}

enum WorkCategory {
  work
  study
  project
  idea
  coding
  competition
  course
}

enum ChatMode {
  instant
  long_memory
}

enum ChatRole {
  user
  assistant
  system
}

enum EntityType {
  entry
  task
  mood
  timeline_event
  work_item
  person
  tag
  file
  chat_message
}

enum AnalysisProvider {
  openai
  qwen
  deepseek
  mock
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String?  @unique
  avatarUrl String?
  timezone   String   @default("Asia/Shanghai")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  entries         Entry[]
  attachments     Attachment[]
  analyses        AiAnalysis[]
  tasks           Task[]
  moods           MoodRecord[]
  timelineEvents  TimelineEvent[]
  tags            Tag[]
  people          Person[]
  workItems       WorkItem[]
  chatSessions    ChatSession[]
  dailySummaries  DailySummary[]
  vectorDocuments VectorDocument[]
  albumItems      AlbumItem[]
  financeItems    FinanceItem[]
}

model Entry {
  id          String    @id @default(cuid())
  userId      String
  contentText String?
  rawContent  String?
  type        String    @default("text")
  inputType   InputType
  sourceUrl   String?
  rawMetadata Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments Attachment[]
  analyses    AiAnalysis[]
  entryAnalysis EntryAnalysis?
  tasks       Task[]
  entryEmotions EntryEmotion[]
  moods       MoodRecord[]
  timelineEvents TimelineEvent[]
  workItems   WorkItem[]
  entryTags   EntryTag[]
  entryPeople EntryPerson[]
  vectorDocuments VectorDocument[]
  albumItems   AlbumItem[]
  financeItems FinanceItem[]
  @@index([userId, createdAt])
}

model Attachment {
  id         String   @id @default(cuid())
  entryId    String?
  userId     String
  fileUrl    String
  fileType   MediaType
  mimeType   String
  size       Int
  duration   Int?
  width      Int?
  height     Int?
  createdAt  DateTime @default(now())

  entry       Entry?        @relation(fields: [entryId], references: [id], onDelete: SetNull)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  albumItems  AlbumItem[]
  vectorDocuments VectorDocument[]
  @@index([userId, createdAt])
}

model AiAnalysis {
  id                     String           @id @default(cuid())
  entryId                String
  userId                 String
  provider               AnalysisProvider
  model                  String
  promptVersion          String
  summary                String?
  moodLabel              String?
  moodScore              Float?
  tags                   Json?
  extractedTasks         Json?
  extractedTimelineEvents Json?
  extractedWorkItems     Json?
  extractedPeople        Json?
  rawAiOutput            Json?
  createdAt              DateTime         @default(now())

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([entryId, createdAt])
}

model EntryAnalysis {
  id                String   @id @default(cuid())
  entryId           String   @unique
  summary           String
  compressedMemory  String
  timelineType      String
  confidence        Float
  rawAiResult       Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
}

model EntryEmotion {
  id         String   @id @default(cuid())
  entryId    String
  name       String
  intensity  Float
  reason     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
}

model Task {
  id          String       @id @default(cuid())
  userId      String
  entryId     String?
  title       String
  description String?
  deadlineText String?
  sourceText  String?
  status      TaskStatus   @default(todo)
  priority    PriorityLevel @default(medium)
  dueDate     DateTime?
  sourceType  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry Entry? @relation(fields: [entryId], references: [id], onDelete: SetNull)
  taskLinks TaskLink[]

  @@index([userId, status, createdAt])
}

model TaskLink {
  id                String   @id @default(cuid())
  taskId            String
  sourceEntryId     String?
  relatedEntityType EntityType
  relatedEntityId   String?
  createdAt         DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model MoodRecord {
  id          String   @id @default(cuid())
  userId      String
  entryId     String?
  moodLabel   String
  moodScore   Float
  reason      String?
  createdAt   DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry Entry? @relation(fields: [entryId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model TimelineEvent {
  id          String            @id @default(cuid())
  userId      String
  entryId     String?
  title       String
  description String?
  eventTime   DateTime
  eventType   TimelineEventType @default(note)
  tags        Json?
  createdAt   DateTime          @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry Entry? @relation(fields: [entryId], references: [id], onDelete: SetNull)

  @@index([userId, eventTime])
}

model Tag {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      String?
  createdAt DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  entryTags EntryTag[]

  @@unique([userId, name])
}

model EntryTag {
  id        String   @id @default(cuid())
  entryId   String
  tagId     String
  confidence Float?
  createdAt DateTime @default(now())

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([entryId, tagId])
}

model Person {
  id        String   @id @default(cuid())
  userId    String
  name      String
  alias     String?
  notes     String?
  createdAt DateTime @default(now())

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  entryPeople EntryPerson[]

  @@unique([userId, name])
}

model EntryPerson {
  id            String   @id @default(cuid())
  entryId       String
  personId      String
  relationType   String?
  confidence     Float?
  createdAt     DateTime @default(now())

  entry  Entry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([entryId, personId])
}

model WorkItem {
  id          String       @id @default(cuid())
  userId      String
  entryId     String?
  category    WorkCategory @default(work)
  projectName String?
  title       String
  description String?
  status      TaskStatus   @default(todo)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry Entry? @relation(fields: [entryId], references: [id], onDelete: SetNull)

  @@index([userId, category, createdAt])
}

model ChatSession {
  id        String    @id @default(cuid())
  userId    String
  title     String?
  mode      ChatMode   @default(instant)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId, createdAt])
}

model ChatMessage {
  id          String   @id @default(cuid())
  sessionId   String
  role        ChatRole
  content     String
  citations   Json?
  createdAt   DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model DailySummary {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  summary   String
  highlights Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model VectorDocument {
  id          String   @id @default(cuid())
  userId      String
  sourceType  EntityType
  entryId     String?
  attachmentId String?
  content     String
  embeddingRef String?
  metadata    Json?
  createdAt   DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry       Entry?       @relation(fields: [entryId], references: [id], onDelete: SetNull)
  attachment  Attachment?  @relation(fields: [attachmentId], references: [id], onDelete: SetNull)

  @@index([userId, sourceType, createdAt])
}

model FinanceItem {
  id         String   @id @default(cuid())
  userId     String
  entryId    String?
  title      String
  amountText String
  type       String
  category   String?
  sourceText String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry Entry? @relation(fields: [entryId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model AlbumItem {
  id           String   @id @default(cuid())
  userId       String
  entryId      String?
  attachmentId String?
  title        String
  description  String?
  mediaUrl     String
  mediaType    MediaType
  takenAt      DateTime?
  createdAt    DateTime @default(now())

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry      Entry?       @relation(fields: [entryId], references: [id], onDelete: SetNull)
  attachment Attachment? @relation(fields: [attachmentId], references: [id], onDelete: SetNull)
}
