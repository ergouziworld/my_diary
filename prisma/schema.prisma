generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InputType {
  text
  image
  audio
  video
  link
  mixed
}

enum TaskStatus {
  todo
  doing
  done
  archived
}

enum FinanceType {
  income
  expense
}

enum MediaType {
  image
  video
  audio
  file
}

enum RecordStatus {
  todo
  doing
  done
  archived
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries     Entry[]
  attachments Attachment[]
  analyses    AiAnalysis[]
  tasks       Task[]
  moods       MoodRecord[]
  timeline    TimelineEvent[]
  finances    FinanceRecord[]
  albumItems  AlbumItem[]
  workItems   WorkItem[]
}

model Entry {
  id          String    @id @default(cuid())
  userId      String
  contentText String?
  inputType   InputType
  sourceUrl   String?
  rawMetadata Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments Attachment[]
  analyses    AiAnalysis[]
  tasks       Task[]
  moods       MoodRecord[]
  timeline    TimelineEvent[]
  finances    FinanceRecord[]
  albumItems  AlbumItem[]
  workItems   WorkItem[]
}

model Attachment {
  id        String   @id @default(cuid())
  entryId   String
  userId    String
  fileUrl   String
  fileType  MediaType
  mimeType  String
  size      Int
  createdAt DateTime @default(now())

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  albumItems AlbumItem[]
}

model AiAnalysis {
  id                      String   @id @default(cuid())
  entryId                 String
  userId                  String
  summary                 String?
  moodLabel               String?
  moodScore               Float?
  tags                    Json?
  extractedTasks          Json?
  extractedFinance        Json?
  extractedTimelineEvents  Json?
  extractedAlbumItems     Json?
  extractedWorkItems      Json?
  rawAiOutput             Json?
  createdAt               DateTime @default(now())

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Task {
  id          String     @id @default(cuid())
  userId      String
  entryId     String?
  title       String
  description String?
  status      TaskStatus @default(todo)
  dueDate     DateTime?
  priority    String     @default("medium")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user  User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry Entry? @relation(fields: [entryId], references: [id], onDelete: SetNull)
}

model MoodRecord {
  id        String   @id @default(cuid())
  userId    String
  entryId   String?
  moodLabel String
  moodScore Float
  note      String?
  createdAt DateTime @default(now())

  user  User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry Entry? @relation(fields: [entryId], references: [id], onDelete: SetNull)
}

model TimelineEvent {
  id          String   @id @default(cuid())
  userId      String
  entryId     String?
  title       String
  description String?
  eventTime   DateTime
  tags        Json?
  createdAt   DateTime @default(now())

  user  User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry Entry? @relation(fields: [entryId], references: [id], onDelete: SetNull)
}

model FinanceRecord {
  id         String      @id @default(cuid())
  userId     String
  entryId    String?
  type       FinanceType
  amount     Decimal     @db.Decimal(12, 2)
  currency   String      @default("CNY")
  category   String?
  note       String?
  occurredAt DateTime
  createdAt  DateTime    @default(now())

  user  User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry Entry? @relation(fields: [entryId], references: [id], onDelete: SetNull)
}

model AlbumItem {
  id           String   @id @default(cuid())
  userId       String
  entryId      String?
  attachmentId String?
  title        String
  description  String?
  mediaUrl     String
  mediaType    MediaType
  takenAt      DateTime?
  createdAt    DateTime @default(now())

  user       User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry      Entry?       @relation(fields: [entryId], references: [id], onDelete: SetNull)
  attachment Attachment? @relation(fields: [attachmentId], references: [id], onDelete: SetNull)
}

model WorkItem {
  id          String   @id @default(cuid())
  userId      String
  entryId     String?
  projectName String?
  title       String
  description String?
  status      RecordStatus @default(todo)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user  User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry Entry? @relation(fields: [entryId], references: [id], onDelete: SetNull)
}
