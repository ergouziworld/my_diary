{
    "name": "my_diary",
    "private": true,
    "version": "0.11.0",
    "main": "electron/main.js",
    "scripts": {
        "dev": "next dev --turbo",
        "dev:world": "next dev --hostname 127.0.0.1 --port 3001",
        "build": "next build",
        "start": "next start",
        "preview": "npm run build && npm run start -- --hostname 127.0.0.1 --port 3000",
        "lint": "next lint",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "electron": "electron .",
        "electron:build": "next build && electron-builder"
    },
    "dependencies": {
        "@alicloud/pop-core": "^1.8.0",
        "@prisma/client": "^6.0.0",
        "@types/pdf-parse": "^1.1.5",
        "bcryptjs": "^3.0.3",
        "next": "^15.0.0",
        "next-auth": "^4.24.14",
        "pdf-parse": "^2.4.5",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "three": "^0.184.0"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/node": "^22.0.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@types/three": "^0.184.1",
        "autoprefixer": "^10.4.0",
        "electron": "^35.0.0",
        "electron-builder": "^25.0.0",
        "eslint": "^9.0.0",
        "eslint-config-next": "^15.0.0",
        "postcss": "^8.4.0",
        "prisma": "^6.0.0",
        "tailwindcss": "^3.4.0",
        "typescript": "^5.6.0"
    },
    "build": {
        "appId": "com.myapp.mydiary",
        "productName": "My Diary",
        "directories": {
            "output": "dist-electron"
        },
        "files": [
            "electron/**/*",
            ".next/**/*",
            "public/**/*",
            "prisma/**/*",
            "node_modules/**/*",
            "package.json"
        ],
        "win": {
            "target": "nsis",
            "icon": "public/favicon.ico"
        },
        "mac": {
            "target": "dmg"
        },
        "linux": {
            "target": "AppImage"
        }
    }
}
